<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <title>Frequência Nickton | Nostalgia 2008-2018</title>
    <style>
        :root {
            --primary: #ff4757; /* Um tom vibrante */
            --secondary: #2f3542;
            --accent: #2ed573; /* Verde neon estilo Ben 10 */
            --bg: #1e1e2e;
            --text: #ffffff;
        }

        body {
            margin: 0;
            font-family: 'Segoe UI', Roboto, sans-serif;
            background-color: var(--bg);
            color: var(--text);
            overflow-x: hidden;
        }

        /* FUNDO DE ESTRELAS/PARTÍCULAS */
        #particles {
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            z-index: -1;
            background: radial-gradient(circle at center, #2c3e50 0%, #000 100%);
        }

        header {
            background: rgba(0, 0, 0, 0.8);
            padding: 40px 20px;
            text-align: center;
            border-bottom: 5px solid var(--primary);
            box-shadow: 0 5px 15px rgba(255, 71, 87, 0.3);
        }

        header h1 {
            margin: 0;
            font-size: 3.5rem;
            letter-spacing: -2px;
            color: var(--text);
            text-transform: uppercase;
            font-style: italic;
            text-shadow: 3px 3px var(--primary), -2px -2px var(--accent);
        }

        header p {
            font-weight: bold;
            color: var(--accent);
            letter-spacing: 2px;
        }

        .container {
            max-width: 1200px;
            margin: 40px auto;
            padding: 20px;
        }

        /* CARDS DE NOTÍCIAS */
        .news-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 25px;
            margin-top: 30px;
        }

        .news-card {
            background: #2f3542;
            border-radius: 10px;
            padding: 20px;
            border-left: 8px solid var(--primary);
            transition: 0.3s;
            position: relative;
            overflow: hidden;
        }

        .news-card:hover {
            transform: scale(1.03);
            background: #3e4452;
        }

        .news-card h3 { color: var(--accent); margin-top: 0; }

        /* WIDGET DO CHATBOT */
        #chat-container {
            position: fixed;
            bottom: 20px;
            right: 20px;
            width: 380px;
            height: 550px;
            background: #ffffff;
            border-radius: 15px;
            display: flex;
            flex-direction: column;
            box-shadow: 0 15px 35px rgba(0,0,0,0.4);
            z-index: 1000;
            color: #333;
            border: 3px solid var(--primary);
        }

        #chat-header {
            background: var(--primary);
            color: white;
            padding: 15px;
            font-weight: bold;
            text-align: center;
            font-size: 1.1rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        #chat-messages {
            flex-grow: 1;
            padding: 15px;
            overflow-y: auto;
            background: #f1f2f6;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .msg {
            max-width: 80%;
            padding: 12px;
            border-radius: 10px;
            font-size: 14px;
            line-height: 1.4;
        }

        .bot-msg { background: #dfe4ea; align-self: flex-start; color: #2f3542; border-bottom-left-radius: 2px; }
        .user-msg { background: var(--primary); color: white; align-self: flex-end; border-bottom-right-radius: 2px; }

        .chat-input-area {
            display: flex;
            padding: 15px;
            background: #fff;
            border-top: 1px solid #ddd;
        }

        #user-input {
            flex-grow: 1;
            padding: 10px;
            border: 2px solid #ddd;
            border-radius: 5px;
            outline: none;
        }

        #send-btn {
            background: var(--primary);
            color: white;
            border: none;
            padding: 0 20px;
            margin-left: 10px;
            border-radius: 5px;
            cursor: pointer;
            font-weight: bold;
        }

        footer {
            text-align: center;
            padding: 60px;
            opacity: 0.6;
        }

    </style>
</head>
<body>

<div id="particles"></div>

